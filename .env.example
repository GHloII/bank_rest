# Copy this file to .env and set your own values.
# Do NOT commit .env to git.

# Ports
APP_PORT=8080
POSTGRES_PORT=5432

# App port inside container / local run
SERVER_PORT=8080

# PostgreSQL
POSTGRES_DB=bank_db
POSTGRES_USER=bank_user
POSTGRES_PASSWORD=bank_password

# Spring datasource envs (used by application.yml and docker-compose)
DB_URL=jdbc:postgresql://postgres:5432/bank_db
DB_USER=bank_user
DB_PASSWORD=bank_password

# For local run (without Docker) you can use:
# DB_URL=jdbc:postgresql://localhost:5432/bank_db

# JWT
JWT_SECRET=mySuperSecretKeyForJwtGenerationThatShouldBeAtLeast32CharactersLong
JWT_EXPIRATION=86400000

# Card PAN encryption
CARD_CRYPTO_SECRET=myCardPanEncryptionSecretThatShouldBeAtLeast32CharactersLong
